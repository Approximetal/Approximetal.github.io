---
import { SITE } from "@/config";
import type { SocialItem } from "@/types";
import Links from "@/components/Links.astro";
import FlipImage from "@/components/FlipImage.astro";
import Layout from "@/layouts/Layout.astro";

const socials: SocialItem[] = [
  { icon: "", link: "/files/cv/Zhiyuan_Zhao_Academic_CV.pdf", name: "CV" },
  { icon: "", link: "mailto:approximetal@gmail.com", name: "Email" },
  { icon: "", link: "https://github.com/Approximetal", name: "GitHub" }
];

const publications = [
  {
    title: "LEMAS: A 150K-Hour Large-scale Extensible Multilingual Audio Suite with Generative Speech Models",
    authors: "Zhiyuan Zhao, Lijian Lin, Ye Zhu, Kai Xie, Yunfei Liu, Yu Li",
    venue: "arXiv:2601.04233, 2026",
    placeholder: "LEMAS",
    links: [
      { label: "PDF", href: "https://arxiv.org/pdf/2601.04233" },
      { label: "Project", href: "https://lemas-project.github.io/LEMAS-Project/" }
    ]
  },
  {
    title: "MelTok: 2D Tokenization for Single-Codebook Audio Compression",
    authors: "Jingyi Li*, Zhiyuan Zhao*, Zhisheng Zhang, Yunfei Liu, Lijian Lin, Ye Zhu, Jiahao Wu, Qiuqiang Kong, Yu Li",
    venue: "arXiv:2510.01903, 2025",
    placeholder: "MelTok",
    links: [{ label: "PDF", href: "https://arxiv.org/pdf/2510.01903" }]
  },
  {
    title: "STFTCodec: High-Fidelity Audio Compression through Time-Frequency Domain Representation",
    authors: "Tao Feng*, Zhiyuan Zhao*, Yifan Xie, Yuqi Ye, Xiangyang Luo, Xun Guan, Yu Li",
    venue: "IEEE ICME, 2025",
    placeholder: "STFTCodec",
    links: [{ label: "PDF", href: "https://arxiv.org/pdf/2503.16989" }]
  },
  {
    title: "Improving Model Stability and Training Efficiency in Fast Speed High Quality Expressive Voice Conversion System",
    authors: "Zhiyuan Zhao, Jingjun Liang, Zehong Zheng, Linhuang Yan, Zhiyong Yang, Wan Ding, Dongyan Huang",
    venue: "ACM ICMI, 2021",
    placeholder: "VC",
    links: [
      {
        label: "PDF",
        href: "https://approximetal.github.io/multi-speaker-VC/doc/ACM_Expressive_Voice_Conversion.pdf"
      },
      { label: "Demo", href: "https://approximetal.github.io/multi-speaker-VC/" }
    ]
  }
];

const featured = [
  {
    tag: "Dataset + Models",
    title: "LEMAS",
    link: "https://lemas-project.github.io/LEMAS-Project/",
    text: "150K+ hours, 10 languages, word-level timestamps, plus TTS/Edit benchmarks.",
    points: ["50K+ downloads", "Generative speech data"]
  },
  {
    tag: "Music AI",
    title: "SVLive",
    link: "https://github.com/Approximetal/SVLive",
    text: "Natural-language live coding with Strudel, Vital, and editable synthesis.",
    points: ["2,300+ presets", "MIDI <-> Strudel"]
  },
  {
    tag: "Product System",
    title: "VoicePlatform",
    link: "https://approximetal.github.io/VoicePlatform/",
    text: "Audio/video AI workflow for ASR, TTS/VC, speech editing, dubbing, and translation.",
    points: ["3-5 min per 1-min video", "Controllable workflow"]
  },
  {
    tag: "Robotics",
    title: "Robot Speech Interaction",
    link: "https://www.youtube.com/watch?v=ssxdSVQN14I",
    text: "Omni speech-interaction LLMs for embodied robots and real-time dialogue.",
    points: ["Post-training data", "Evaluation pipeline"]
  }
];
---

<Layout class="about" title={SITE.title}>
  <section class="grid gap-7 md:grid-cols-[1fr_10rem] md:items-end">
    <div class="hero-title">
      <div class="name-row my-1.5">
        <h1 my-0>Zhiyuan Zhao</h1>
        <Links socials={socials} />
      </div>
    </div>
    <div class="size-30 md:size-38 md:mt-2">
      <FlipImage front="https://github.com/Approximetal.png" alt="Zhiyuan Zhao" />
    </div>
  </section>

  <section class="hero-bio">
    <p>
      I am a Senior Research Engineer at <a href="https://www.xpeng.com/">XPENG Robotics</a>, responsible for
      speech interaction on the <a href="https://www.youtube.com/watch?v=ssxdSVQN14I">IRON humanoid robot</a>.
      My research interests include generative speech/audio, speech-native interaction for embodied robots, and
      natural-language interfaces for controllable music creation.
    </p>
    <p>
      Previously, I worked at <a href="https://www.idea.edu.cn/">IDEA Research</a>,
      <a href="https://www.ubtrobot.com/en/">UBTECH Robotics</a>, and
      <a href="https://www.sf-tech.com.cn/">SF Tech</a>, and interned at
      <a href="https://research.samsung.com/src-b">Samsung Research China - Beijing</a>.
      I received my M.Sc. in Robotics from <a href="https://www.kcl.ac.uk/research/core">King's College London</a>
      and my B.Sc. in Electronic Information Science and Technology from
      <a href="https://wl.csu.edu.cn/English.htm">Central South University</a>.
    </p>
  </section>

  <section mt-12>
    <h2>Publications</h2>
    <div class="publication-list">
      {publications.map((item) => (
        <article class="publication-item">
          <div class="publication-thumb">
            <span>{item.placeholder}</span>
          </div>
          <div class="publication-copy">
            <h3>{item.title}</h3>
            <p class="publication-authors">{item.authors}</p>
            <p class="publication-venue">{item.venue}</p>
            <div class="publication-links">
              {item.links.map((link) => (
                <a href={link.href} target="_blank" rel="noopener noreferrer">
                  {link.label}
                </a>
              ))}
            </div>
          </div>
        </article>
      ))}
    </div>
  </section>

  <section mt-12>
    <h2>Featured Projects</h2>
    <div grid="~ cols-1 md:cols-2 gap-2">
      {featured.map((item) => (
        <a class="home-card project-home-card !no-underline !text-fg" href={item.link}>
          <div class="card-kicker">{item.tag}</div>
          <h3>{item.title}</h3>
          <p>{item.text}</p>
          <div class="project-tags">
            {item.points.map((point) => <span>{point}</span>)}
          </div>
        </a>
      ))}
    </div>
  </section>

  <section mt-12>
    <h2>Open Source</h2>
    <div grid="~ cols-1 sm:cols-2 gap-2">
      <a class="mini-card !no-underline !text-fg" href="https://github.com/Approximetal/SVLive">
        <strong>SVLive</strong>
        <span>Strudel + Vital + LLM live coding</span>
      </a>
      <a class="mini-card !no-underline !text-fg" href="https://lemas-project.github.io/LEMAS-Project/">
        <strong>LEMAS</strong>
        <span>150K+ hr multilingual speech corpus</span>
      </a>
      <a class="mini-card !no-underline !text-fg" href="https://approximetal.github.io/VoicePlatform/">
        <strong>VoicePlatform</strong>
        <span>Speech/video AI workflow demo</span>
      </a>
      <a class="mini-card !no-underline !text-fg" href="https://github.com/UmiMarch/OpenVideo/">
        <strong>OpenVideo</strong>
        <span>672h / 106K+ text-to-video dataset</span>
      </a>
    </div>
  </section>

  <section mt-12>
    <h2>Beyond Research</h2>
    <div grid="~ cols-2 md:cols-5 gap-2">
      {["Photography", "Travel", "Music", "Cycling", "Reading"].map((item) => (
        <div class="small-card">{item}</div>
      ))}
    </div>
  </section>

</Layout>

<style>
  .home-card,
  .mini-card,
  .small-card {
    border: 1px solid hsl(var(--border));
    background: hsl(var(--bg-dark) / 0.35);
    border-radius: 0.5rem;
  }

  .hero-title {
    padding-bottom: 0.15rem;
  }

  .name-row {
    display: flex;
    align-items: flex-end;
    flex-wrap: wrap;
    gap: 0.45rem 1rem;
  }

  .name-row :global(div[flex]) {
    align-items: flex-end;
    margin-bottom: 0.08rem;
  }

  .name-row :global(a.btn) {
    margin-bottom: 0;
  }

  .hero-bio {
    margin-top: 1.8rem;
    max-width: 48rem;
  }

  .hero-bio p {
    margin: 0.55rem 0 0;
    color: hsl(var(--fg-light));
    line-height: 1.6;
  }

  .publication-list {
    display: grid;
    gap: 1rem;
  }

  .publication-item {
    display: grid;
    grid-template-columns: 9.5rem minmax(0, 1fr);
    gap: 1rem;
    align-items: start;
  }

  .publication-thumb {
    aspect-ratio: 4 / 3;
    align-items: center;
    background: hsl(var(--bg-dark) / 0.35);
    border: 1px dashed hsl(var(--border));
    border-radius: 0.45rem;
    color: hsl(var(--fg-light));
    display: flex;
    font-size: 0.78rem;
    font-weight: 700;
    justify-content: center;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .publication-copy h3 {
    font-size: 1rem;
    line-height: 1.35;
    margin: 0 0 0.3rem;
  }

  .publication-copy p,
  .publication-links {
    font-size: 0.9rem;
    line-height: 1.42;
    margin: 0.2rem 0;
  }

  .publication-authors,
  .publication-venue {
    color: hsl(var(--fg-light));
  }

  .publication-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .home-card p,
  .mini-card span {
    color: hsl(var(--fg-light));
  }

  .home-card,
  .mini-card {
    display: block;
    padding: 1rem;
    transition:
      border-color 160ms ease,
      background 160ms ease,
      box-shadow 160ms ease,
      transform 160ms ease;
  }

  a.home-card:hover,
  a.mini-card:hover {
    border-color: hsl(var(--primary) / 0.45);
    background: hsl(var(--bg-dark) / 0.72);
    box-shadow: 0 0.75rem 1.8rem hsl(var(--fg-dark) / 0.08);
    transform: translateY(-2px);
    text-decoration: none !important;
  }

  .home-card h3 {
    margin-top: 0.15rem;
  }

  .card-kicker {
    color: hsl(var(--fg-light));
    font-size: 0.82rem;
    font-weight: 700;
  }

  .project-home-card {
    min-height: 11.5rem;
  }

  .compact-list {
    margin-bottom: 0;
  }

  .project-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-top: 0.85rem;
  }

  .project-tags span {
    border: 1px solid hsl(var(--border));
    border-radius: 999px;
    color: hsl(var(--fg-light));
    font-size: 0.76rem;
    padding: 0.16rem 0.5rem;
  }

  .mini-card strong {
    display: block;
    margin-bottom: 0.2rem;
  }

  .small-card {
    padding: 0.85rem;
    text-align: center;
    font-weight: 700;
  }

  @media (max-width: 640px) {
    .publication-item {
      grid-template-columns: 1fr;
    }

    .publication-thumb {
      max-width: 13rem;
    }
  }
</style>
