---

<Layout class="about" title={SITE.title}>
  <section class="grid gap-7 md:grid-cols-[1fr_10rem] md:items-end">
    <div class="hero-title">
      <div class="name-row my-1.5">
        <h1 my-0>Zhiyuan Zhao</h1>
        <Links socials={socials} />
      </div>
    </div>
    <div class="size-30 md:size-38 md:mt-2">
      <FlipImage
        front="/img/avatar-front-original.png"
        back="/img/avatar-back.png"
        alt="Zhiyuan Zhao"
      />
    </div>
  </section>

  <section class="hero-bio">
    <p>
      I am a Senior Research Engineer at <a href="https://www.xpeng.com/">XPENG Robotics</a>, responsible for
      speech interaction on the <a href="https://www.youtube.com/watch?v=ssxdSVQN14I">IRON humanoid robot</a>.
      My research interests include generative speech/audio, speech-native interaction for embodied robots, and
      natural-language interfaces for controllable music creation.
    </p>
    <p>
      Previously, I worked at <a href="https://www.idea.edu.cn/">IDEA Research</a>,
      <a href="https://www.ubtrobot.com/en/">UBTECH Robotics</a>, and
      <a href="https://www.sf-tech.com.cn/">SF Tech</a>, and interned at
      <a href="https://research.samsung.com/src-b">Samsung Research China - Beijing</a>.
      I received my M.Sc. in Robotics from <a href="https://www.kcl.ac.uk/research/core">King's College London</a>
      and my B.Sc. in Electronic Information Science and Technology from
      <a href="https://wl.csu.edu.cn/English.htm">Central South University</a>.
    </p>
  </section>

  <section mt-12>
    <h2>Publications</h2>
    <div class="publication-list">
      {publications.map((item) => (
        <article class="publication-item">
          <div class="publication-thumb">
            <img src={item.image} alt={`${item.placeholder} preview`} loading="lazy" />
            <span>{item.placeholder}</span>
          </div>
          <div class="publication-copy">
            <h3>{item.title}</h3>
            <p class="publication-authors">{item.authors}</p>
            <p class="publication-venue">{item.venue}</p>
            <div class="publication-links">
              {item.links.map((link) => (
                <a href={link.href} target="_blank" rel="noopener noreferrer">
                  {link.label}
                </a>
              ))}
            </div>
          </div>
        </article>
      ))}
    </div>
  </section>

  <section mt-12>
    <h2>Open Source Projects</h2>
    <div class="card-grid">
      {featured.map((item) => (
        <a class="home-card project-home-card !no-underline !text-fg" href={item.link}>
          <div class="project-card-head">
            <div class="project-card-title">
              <div class="card-kicker">{item.tag}</div>
              <h3>{item.title}</h3>
            </div>
            <div class="project-logo">
              <img src={item.logo} alt={`${item.title} logo`} loading="lazy" />
              <span>logo</span>
            </div>
          </div>
          <p>{item.text}</p>
          <div class="project-tags">
            {item.points.map((point) => <span>{point}</span>)}
          </div>
        </a>
      ))}
    </div>
  </section>

  <section mt-12>
    <h2>Demos</h2>
    <div class="demo-grid">
      {demos.map((item) => (
        item.kind === "blog" ? (
          <a class="demo-card demo-link-card blog-demo-card !no-underline !text-fg" href={item.link}>
            <div class="demo-code-thumb blog-preview-thumb" aria-label={`${item.title} article preview`}>
              <div class="code-window-bar">
                <span></span>
                <span></span>
                <span></span>
                <strong>{item.meta}</strong>
              </div>
              <pre>{item.preview?.map((line) => <code>{line}</code>)}</pre>
            </div>
            <div class="demo-copy">
              <h3>{item.title}</h3>
              <p>{item.text}</p>
            </div>
          </a>
        ) : item.link ? (
          <a class="demo-card demo-link-card !no-underline !text-fg" href={item.link} target="_blank" rel="noopener noreferrer">
            <div class="demo-code-thumb" aria-label={`${item.title} code preview`}>
              <div class="code-window-bar">
                <span></span>
                <span></span>
                <span></span>
                <strong>dreamy_demo.strudel.js</strong>
              </div>
              <pre>{item.preview?.map((line) => <code>{line}</code>)}</pre>
            </div>
            <div class="demo-copy">
              <h3>{item.title}</h3>
              <p>{item.text}</p>
            </div>
          </a>
        ) : (
          <article class="demo-card">
            <div class="demo-placeholder">
              <span>demo placeholder</span>
            </div>
            <div class="demo-copy">
              <h3>{item.title}</h3>
              <p>{item.text}</p>
            </div>
          </article>
        )
      ))}
    </div>
  </section>

  <p class="to-be-continued">To Be Continued</p>

</Layout>

<style>
  .home-card,
  .demo-card {
    border: 1px solid hsl(var(--border));
    background: hsl(var(--bg-dark) / 0.42);
    border-radius: 0.5rem;
  }

  .card-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.75rem;
  }

  .demo-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.75rem;
  }

  .to-be-continued {
    color: hsl(var(--fg-light));
    font-size: 0.9rem;
    font-style: italic;
    margin: 3rem 0 0;
    text-align: center;
  }

  .hero-title {
    padding-bottom: 0.15rem;
  }

  .name-row {
    display: flex;
    align-items: flex-end;
    flex-wrap: wrap;
    gap: 0.45rem 1rem;
  }

  .name-row :global(div[flex]) {
    align-items: flex-end;
    margin-bottom: 0.08rem;
  }

  .name-row :global(a.btn) {
    margin-bottom: 0;
  }

  .hero-bio {
    margin-top: 1.8rem;
    max-width: 48rem;
  }

  .hero-bio p {
    margin: 0.55rem 0 0;
    color: hsl(var(--fg-light));
    line-height: 1.6;
  }

  .publication-list {
    display: grid;
    gap: 1rem;
  }

  .publication-item {
    display: grid;
    grid-template-columns: clamp(6.5rem, 22vw, 9.5rem) minmax(0, 1fr);
    gap: 0.95rem;
    align-items: start;
  }

  .publication-thumb {
    aspect-ratio: 4 / 3;
    align-items: center;
    background: transparent;
    border: 0;
    border-radius: 0.45rem;
    color: hsl(var(--fg-light));
    display: flex;
    font-size: 0.78rem;
    font-weight: 700;
    justify-content: center;
    letter-spacing: 0.04em;
    overflow: hidden;
    position: relative;
    text-transform: uppercase;
  }

  .publication-thumb span {
    border: 1px dashed hsl(var(--border));
    border-radius: 0.45rem;
    padding: 0.65rem 0.9rem;
    position: relative;
    z-index: 1;
  }

  .publication-thumb img {
    display: block;
    height: 100%;
    margin: 0 !important;
    object-fit: contain;
    object-position: center;
    padding: 0.25rem;
    width: 100%;
  }

  .publication-thumb img[src] + span {
    display: none;
  }

  .publication-copy h3 {
    font-size: 1rem;
    line-height: 1.35;
    margin: 0 0 0.3rem;
  }

  .publication-copy p,
  .publication-links {
    font-size: 0.9rem;
    line-height: 1.42;
    margin: 0.2rem 0;
  }

  .publication-authors,
  .publication-venue {
    color: hsl(var(--fg-light));
  }

  .publication-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .home-card p,
  .demo-card p {
    color: hsl(var(--fg-light));
  }

  .home-card {
    display: block;
    padding: 1rem;
    transition:
      border-color 160ms ease,
      background 160ms ease,
      box-shadow 160ms ease,
      transform 160ms ease;
  }

  a.home-card:hover {
    border-color: hsl(var(--primary) / 0.45);
    background: hsl(var(--bg-dark) / 0.72);
    box-shadow: 0 0.75rem 1.8rem hsl(var(--fg-dark) / 0.08);
    transform: translateY(-2px);
    text-decoration: none !important;
